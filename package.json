{
  "name": "vue-virtual-scroller-next",
  "version": "1.6.2",
  "type": "module",
  "packageManager": "pnpm@10.15.1",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "url": "https://github.com/aikilan/vue3-virtual-scroller"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "ci:tarball-import-named": "node ./scripts/check-tarball-import-named.mjs",
    "dev": "vite",
    "build": "pnpm type-check && pnpm build:lib && pnpm build:demo",
    "build:demo": "vite build",
    "build:lib": "vite build --config vite.lib.config.ts && vue-tsc --noEmit -p tsconfig.lib.json && pnpm build:types && lessc src/library.less dist/style.css",
    "build:types": "node ./scripts/build-types.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "vue-tsc --noEmit -p tsconfig.app.json && vue-tsc --noEmit -p tsconfig.lib.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "peerDependencies": {
    "vue": ">=3.2.4 <4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "1.10.2",
    "@vitejs/plugin-vue-jsx": "1.3.10",
    "@vue/compiler-sfc": "3.2.4",
    "@vue/server-renderer": "3.2.4",
    "@vue/test-utils": "^2.4.6",
    "c8": "11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "less": "^4.6.3",
    "prettier": "^3.8.1",
    "rollup": "^4.60.1",
    "rollup-plugin-dts": "^6.4.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "2.9.18",
    "vitest": "0.12.6",
    "vue": "3.2.4",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.5"
  }
}
